# Simulation Mode (true for mock logging, false for real dispatch)
SIMULATION_MODE=true

# Database (Default for development)
DATABASE_URL=sqlite+aiosqlite:///./breach.db

# Twilio (Required for SMS/WhatsApp when SIMULATION_MODE=false)
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=your_twilio_number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SMTP Settings (Required for Real Emails when SIMULATION_MODE=false)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=simulator@alphacore.io

# Application
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
SIM_BASE_URL=http://localhost:8000
