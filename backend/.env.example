# Simulation Mode (true for mock logging, false for real dispatch)
SIMULATION_MODE=true

# Database
# For SQLite (local dev): sqlite+aiosqlite:///./breach.db
# For Supabase (PostgreSQL): postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./breach.db

# RAG Chatbot (Groq)
GROQ_API_KEY=your_groq_api_key_here

# VirusTotal (optional)
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# Application
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
SIM_BASE_URL=http://localhost:8000
